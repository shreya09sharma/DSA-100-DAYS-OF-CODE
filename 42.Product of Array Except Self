#include <stdio.h>

int main() {
    int n, i;

    printf("Enter number of elements: ");
    scanf("%d", &n);

    int arr[n];
    int left[n], right[n], result[n];

    printf("Enter elements:\n");
    for(i = 0; i < n; i++) {
        scanf("%d", &arr[i]);
    }

    
    left[0] = 1;
    for(i = 1; i < n; i++) {
        left[i] = left[i-1] * arr[i-1];
    }

    
    right[n-1] = 1;
    for(i = n-2; i >= 0; i--) {
        right[i] = right[i+1] * arr[i+1];
    }

    
    for(i = 0; i < n; i++) {
        result[i] = left[i] * right[i];
    }

    
    printf("Product Array:\n");
    for(i = 0; i < n; i++) {
        printf("%d ", result[i]);
    }

    return 0;
}
